# WalletConnect
VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# Firebase (legacy — lock down Firestore rules or remove if fully migrated)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# API
VITE_API_URL=https://your-backend-url.com
VITE_RELAYER_API_URL=https://your-relayer-url.com

# Admin API key — WARNING: VITE_ vars are visible in the JS bundle.
# Replace with wallet-signature auth when possible.
VITE_ADMIN_API_KEY=your_admin_api_key

# Pinata (IPFS)
VITE_PINATA_JWT=your_pinata_jwt

# DonateOnChain Contract
VITE_CONTRACT_ADDRESS=0x_your_proxy_address
VITE_PROXY_ADDRESS=0x_your_proxy_address
VITE_IMPLEMENTATION_ADDRESS=0x_your_implementation_address
VITE_CONTRACT_ID=0.0.your_contract_id

# Network
VITE_CHAIN_ID=296
VITE_NETWORK_NAME=hedera-testnet
VITE_RPC_URL=https://testnet.hashio.io/api
VITE_EXPLORER_URL=https://hashscan.io/testnet

# Platform wallet addresses
VITE_PLATFORM_WALLET=0x_platform_treasury_wallet
VITE_PLATFORM_ADMIN=0x_platform_admin_wallet
VITE_PLATFORM_COMPLIANCE_OFFICER=0x_compliance_officer_wallet
VITE_PLATFORM_CAMPAIGN_MANAGER=0x_campaign_manager_wallet
