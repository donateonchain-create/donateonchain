{
  "name": "donateonchain",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node node_modules/typescript/bin/tsc -b && node node_modules/vite/bin/vite build --mode production",
