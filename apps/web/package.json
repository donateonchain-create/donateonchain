    "@tanstack/react-query": "^5.90.5",
    "hashconnect": "^3.0.14",
    "ipfs-http-client": "^60.0.1",
    "lucide-react": "^0.546.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.9.4",
    "viem": "^2.45.1",
    "wagmi": "^2.18.2"
  },
  "overrides": {
