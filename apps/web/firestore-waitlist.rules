rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /waitlist/{docId} {
      // Anyone can write their own entry (email as docId) but they cannot read it or anyone else's
      allow create: if request.auth == null
                    && request.resource.data.keys().hasOnly(['email','role','joinedAt', 'source'])
                    && request.resource.data.email is string
                    && request.resource.data.email.size() <= 254
                    && request.resource.data.role in ['donor','creator','ngo']
                    && request.resource.data.source == 'waitlist-landing';

      // No public reads at all — neither get nor list
      allow read: if false;

      // No updates or deletes from client
      allow update, delete: if false;
    }
  }
}
